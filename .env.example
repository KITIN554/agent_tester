# DeepSeek через proxyapi.ru (используется для всех LLM-вызовов)
PROXY_API_KEY=your_proxyapi_key_here
PROXY_BASE_URL=https://api.proxyapi.ru/deepseek
LLM_MODEL=deepseek-chat

# Опционально: модель для судьи (можно использовать ту же или другую)
JUDGE_MODEL=deepseek-chat

# Бюджет на прогон (в долларах) — мягкий лимит для защиты
RUN_BUDGET_USD=5.00
