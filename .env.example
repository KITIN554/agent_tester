# Proxyapi.ru → OpenRouter (используется для всех LLM-вызовов)
PROXY_API_KEY=your_proxyapi_key_here
PROXY_BASE_URL=https://api.proxyapi.ru/openrouter/v1
LLM_MODEL=mistralai/mistral-medium-3.1

# Опционально: модель для судьи (можно использовать ту же или другую)
JUDGE_MODEL=mistralai/mistral-medium-3.1

# Бюджет на прогон (в долларах) — мягкий лимит для защиты
RUN_BUDGET_USD=5.00
